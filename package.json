    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.8.5",
    "grammy": "^1.43.0",
    "next": "^16.2.9",
    "node-cron": "^3.0.3",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
