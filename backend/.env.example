PORT=3001

# Telegram — get from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=generate_a_random_32char_secret_here

# Comma-separated Telegram user IDs allowed to use the bot
# Find yours by messaging @userinfobot on Telegram
ALLOWED_TELEGRAM_USER_IDS=123456789

# Dashboard session signing — must be at least 32 random characters
# Generate: openssl rand -hex 32
SESSION_SECRET=generate_a_random_64char_hex_here

# Comma-separated allowed CORS origins for the dashboard (optional, defaults below)
# ALLOWED_ORIGINS=https://bahuleyan.com,http://localhost:3000

# Postgres — local dev
DATABASE_URL=postgres://postgres:postgres@localhost:5432/khata

# OpenRouter — unified API for Claude, MiniMax, GPT, Gemini, DeepSeek, etc.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# (Optional) Override the LLM per intent. Defaults: Haiku 4.5 for the hot text
# path, Sonnet 4.6 for vision and statement normalization. Use OpenRouter model
# IDs (e.g. anthropic/claude-haiku-4-5, minimax/minimax-m1, openai/gpt-4o-mini).
# MODEL_PARSE_EXPENSE=anthropic/claude-haiku-4-5
# MODEL_CLASSIFY_MESSAGE=anthropic/claude-haiku-4-5
# MODEL_NORMALIZE_TRANSACTIONS=anthropic/claude-sonnet-4-6
# MODEL_EXTRACT_TEXT_FROM_IMAGE=anthropic/claude-sonnet-4-6
# MODEL_OCR_RECEIPT_IMAGE=anthropic/claude-sonnet-4-6

# S3-compatible storage (Cloudflare R2, MinIO, etc.)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=khata-statements
S3_REGION=auto
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
