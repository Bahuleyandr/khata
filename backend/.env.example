PORT=3001

# Telegram — get from BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Find yours by messaging @userinfobot on Telegram
ALLOWED_TELEGRAM_USER_IDS=123456789

# Dashboard session signing — must be at least 32 random characters
# Generate: openssl rand -hex 32
SESSION_SECRET=generate_a_random_64char_hex_here

# Comma-separated allowed CORS origins for the dashboard. In production the
# frontend is served from the same Tailscale hostname as the backend (path
# routing via Traefik) so CORS is mostly a non-issue; this defaults to
# localhost for the Next.js dev server.
# ALLOWED_ORIGINS=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/khata

# MiniMax — one key for both the chat completions endpoint (text intents) and
# the minimax-coding-plan-mcp server (vision via understand_image).
# Get a key at https://platform.minimax.io
MINIMAX_API_KEY=your_minimax_api_key_here

# (Optional) Per-intent model override for text intents. Defaults to
# MiniMax-M2.7-highspeed across the board. Vision intents (extractTextFromImage,
# ocrReceiptImage) always go through the MCP `understand_image` tool — no
# direct model selection there.
# MODEL_PARSE_EXPENSE=MiniMax-M2.7-highspeed
# MODEL_CLASSIFY_MESSAGE=MiniMax-M2.7-highspeed
# MODEL_NORMALIZE_TRANSACTIONS=MiniMax-M2.7-highspeed

# S3-compatible storage (Cloudflare R2, MinIO, etc.)
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_BUCKET=khata-statements
S3_REGION=auto
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
