{
  "name": "khata-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "node dist/db/migrate.js",
    "migrate:dev": "tsx src/db/migrate.ts",
    "lint": "eslint src --ext .ts",
    "secrets:scan": "node ../scripts/scan-secrets.mjs",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run secrets:scan && npm run audit:all && npm run lint && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:all": "npm audit --audit-level=moderate",
    "parser:evaluate": "tsx src/parser/evaluate.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pdf-parse": "^1.1.5",
    "exceljs": "^4.4.0",
    "fastify": "^5.0.0",
    "grammy": "^1.26.0",
    "node-cron": "^4.5.0",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "14.0.0"
  }
}
